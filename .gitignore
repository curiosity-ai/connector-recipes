**/.launchSettings.json
**/*.launchSettings.json
**/**/.launchSettings.json
**/**/*.launchSettings.json
**/**/**/.launchSettings.json
**/**/**/*.launchSettings.json
**/**/**/**/.launchSetting.json
**/**/**/**/*.launchSettings.json
**/**/**/**/**/.launchSettings.json
**/**/**/**/**/*.launchSettings.json